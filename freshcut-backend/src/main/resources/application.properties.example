# Copy this file to application.properties and fill in your values

spring.datasource.url=jdbc:mysql://${MYSQLHOST:localhost}:${MYSQLPORT:3306}/${MYSQLDATABASE:freshcut}
spring.datasource.username=${MYSQLUSER:root}
spring.datasource.password=${MYSQLPASSWORD:your_db_password}
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false

jwt.secret=${JWT_SECRET:your_jwt_secret_base64_encoded_min_32_chars}
jwt.expiration=86400000

cloudinary.cloud-name=${CLOUDINARY_CLOUD_NAME:your_cloud_name}
cloudinary.api-key=${CLOUDINARY_API_KEY:your_api_key}
cloudinary.api-secret=${CLOUDINARY_API_SECRET:your_api_secret}

spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB

FRONTEND_URL=${FRONTEND_URL:http://localhost:5173}

spring.cache.type=simple
